<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HP Cricket Equipment</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

<header>
    <h1>HP Cricket Equipment</h1>
    <p>Premium English Willow Bats & Professional Player Edition Gloves</p>
</header>

<section class="products">

    <h2>Cricket Bats</h2>
    <div class="product-grid">

        <div class="product-card">
            <img src="bat1.jpg" alt="Cricket Bat 1">
            <h3>HP Premium English Willow</h3>
            <p>Hand‑crafted, professional grade bat with black grip and gold HP branding.</p>
            <span class="price">£249.99</span>
        </div>

        <div class="product-card">
            <img src="bat2.jpg" alt="Cricket Bat 2">
            <h3>HP Elite English Willow</h3>
            <p>Polished finish, hex‑pattern design, and reinforced spine for maximum power.</p>
            <span class="price">£279.99</span>
        </div>

    </div>

    <h2>Batting Gloves</h2>
    <div class="product-grid">

        <div class="product-card">
            <img src="gloves1.jpg" alt="Batting Gloves 1">
            <h3>HP Player Edition Gloves</h3>
            <p>White & gold honeycomb padding with reinforced finger protection.</p>
            <span class="price">£69.99</span>
        </div>

        <div class="product-card">
            <img src="gloves2.jpg" alt="Batting Gloves 2">
            <h3>HP Elite Gloves</h3>
            <p>Mesh ventilation, ergonomic shaping, and premium gold detailing.</p>
            <span class="price">£79.99</span>
        </div>

    </div>

</section>

<section class="order-form">
    <h2>Place an Order</h2>

    <form action="#" method="POST">
        <label>Your Name</label>
        <input type="text" name="name" required>

        <label>Email Address</label>
        <input type="email" name="email" required>

        <label>Select Product</label>
        <select name="product" required>
            <option value="">Choose an item</option>
            <option>HP Premium English Willow Bat - £249.99</option>
            <option>HP Elite English Willow Bat - £279.99</option>
            <option>HP Player Edition Gloves - £69.99</option>
            <option>HP Elite Gloves - £79.99</option>
        </select>

        <label>Quantity</label>
        <input type="number" name="quantity" min="1" value="1" required>

        <label>Additional Notes</label>
        <textarea name="notes" rows="4"></textarea>

        <button type="submit">Submit Order</button>
    </form>
</section>

<footer>
    <p>© 2026 HP Cricket Equipment</p>
</footer>

</body>
</html>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f4f4;
    color: #222;
}

header {
    background: #0a1a33;
    color: white;
    text-align: center;
    padding: 40px 20px;
}

.products {
    padding: 40px 20px;
}

h2 {
    margin-top: 40px;
    color: #0a1a33;
}

.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.product-card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    text-align: center;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

.product-card img {
    width: 100%;
    border-radius: 10px;
}

.price {
    display: block;
    margin-top: 10px;
    font-weight: bold;
    color: #d4a017;
}

.order-form {
    background: white;
    padding: 40px 20px;
    margin: 40px 0;
}

form {
    max-width: 500px;
    margin: auto;
    display: flex;
    flex-direction: column;
}

input, select, textarea {
    padding: 10px;
    margin: 10px 0;
    border-radius: 6px;
    border: 1px solid #ccc;
}

button {
    padding: 12px;
    background: #0a1a33;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
}

button:hover {
    background: #12345a;
}

footer {
    text-align: center;
    padding: 20px;
    background: #0a1a33;
    color: white;
}
